# === Server ===
PORT=5000
NODE_ENV=development

# === Database ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collab_db
DB_USER=collab_user
DB_PASSWORD=collab_pass

# === JWT ===
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d

# === Yandex OAuth (ЗАПОЛНИТЕ СВОИМИ ЗНАЧЕНИЯМИ) ===
# Получить ключи: https://oauth.yandex.ru/client/new
# Доступные scope: login:info, login:avatar, login:email
# Примечание: playlist:read/write НЕдоступны в публичном OAuth Яндекса (2026)
# Для работы с плейлистами используем обходные пути (сохранение в БД приложения)
YANDEX_CLIENT_ID=your_client_id_here
YANDEX_CLIENT_SECRET=your_client_secret_here
YANDEX_REDIRECT_URI=http://localhost:3000/auth/callback

# === Frontend ===
FRONTEND_URL=http://localhost:3000
